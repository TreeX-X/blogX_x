---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath
    ? `${normalizedBase}/${normalizedPath}`
    : `${normalizedBase}/`;
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={toBase("logo/treeXLogo.png")} />
    <title>{title}</title>
  </head>
  <body>
    <div id="cursorGlow" class="cursor-glow" aria-hidden="true"></div>
    <div class="pixel-clock" aria-hidden="true">
      <div class="pixel-clock__shell">
        <div class="pixel-clock__display">
          <div class="pixel-clock__pair">
            <span id="pixelClockHourA" class="pixel-clock__digit" data-digit="0"></span>
            <span id="pixelClockHourB" class="pixel-clock__digit" data-digit="0"></span>
          </div>
          <span class="pixel-clock__separator" aria-hidden="true"></span>
          <div class="pixel-clock__pair">
            <span id="pixelClockMinuteA" class="pixel-clock__digit" data-digit="0"></span>
            <span id="pixelClockMinuteB" class="pixel-clock__digit" data-digit="0"></span>
          </div>
        </div>
      </div>
    </div>
    <header class="site-header">
      <div class="container inner">
        <a class="brand" href={toBase()}>BlogX_x</a>
        <button
          id="menuToggle"
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="siteNav"
          type="button"
        >
          Menu
        </button>
        <nav id="siteNav" class="nav-links" data-open="false">
          <a href={toBase()}>首页</a>
          <a href={toBase("posts")}>文章</a>
          <a href={toBase("knowledge-base")}>知识库</a>
          <a href={toBase("about")}>关于</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">© {currentYear} BlogX_x's Digital Garden.</div>
    </footer>

    <script>
      const button = document.getElementById("menuToggle");
      const nav = document.getElementById("siteNav");
      const glow = document.getElementById("cursorGlow");
      const hourA = document.getElementById("pixelClockHourA");
      const hourB = document.getElementById("pixelClockHourB");
      const minuteA = document.getElementById("pixelClockMinuteA");
      const minuteB = document.getElementById("pixelClockMinuteB");
      let frame = 0;

      if (button && nav) {
        button.addEventListener("click", () => {
          const isOpen = nav.dataset.open === "true";
          nav.dataset.open = String(!isOpen);
          button.setAttribute("aria-expanded", String(!isOpen));
        });
      }

      const updateGlow = (x, y) => {
        if (!glow) return;
        glow.style.left = `${x}px`;
        glow.style.top = `${y + 22}px`;
      };

      const updateClock = () => {
        if (!hourA || !hourB || !minuteA || !minuteB) return;
        const now = new Date();
        const hours = String(now.getHours()).padStart(2, "0");
        const minutes = String(now.getMinutes()).padStart(2, "0");
        hourA.dataset.digit = hours[0];
        hourB.dataset.digit = hours[1];
        minuteA.dataset.digit = minutes[0];
        minuteB.dataset.digit = minutes[1];
      };

      window.addEventListener("pointermove", (event) => {
        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          updateGlow(event.clientX, event.clientY);
          frame = 0;
        });
      });

      window.addEventListener("mousemove", (event) => {
        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          updateGlow(event.clientX, event.clientY);
          frame = 0;
        });
      });

      window.addEventListener(
        "pointerleave",
        () => {
          updateGlow(window.innerWidth * 0.5, window.innerHeight * 0.22);
        },
        { passive: true },
      );

      updateClock();
      window.setInterval(updateClock, 1000);
    </script>
  </body>
</html>
