---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath
    ? `${normalizedBase}/${normalizedPath}`
    : `${normalizedBase}/`;
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={toBase("logo/treeXLogo.png")} />
    <title>{title}</title>
  </head>
  <body>
    <canvas id="starfield" class="starfield-canvas" aria-hidden="true"></canvas>
    <div id="cursorGlow" class="cursor-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div class="container inner">
        <a class="brand" href={toBase()}>BlogX_x</a>
        <button
          id="menuToggle"
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="siteNav"
          type="button"
        >
          Menu
        </button>
        <nav id="siteNav" class="nav-links" data-open="false">
          <a href={toBase()}>首页</a>
          <a href={toBase("posts")}>文章</a>
          <a href={toBase("knowledge-base")}>知识库</a>
          <a href={toBase("toolbox")}>工具箱</a>
          <a href={toBase("about")}>关于</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div>
            <div class="footer-brand">BlogX_x</div>
            <p class="footer-desc">
              个人数字花园 — 沉淀技术文章、知识库与工具集，持续迭代。
            </p>
          </div>
          <div class="footer-links">
            <div class="footer-col">
              <h4>内容</h4>
              <a href={toBase("posts")}>文章</a>
              <a href={toBase("knowledge-base")}>知识库</a>
              <a href={toBase("toolbox")}>工具箱</a>
            </div>
            <div class="footer-col">
              <h4>关于</h4>
              <a href={toBase("about")}>关于我</a>
              <a href="https://github.com/anthropics/claude-code" target="_blank" rel="noopener">GitHub</a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; {currentYear} BlogX_x's Digital Garden.</span>
          <span>Powered by Astro &amp; Claude</span>
        </div>
      </div>
    </footer>

    <script>
      /*-- Starfield canvas --*/
      (function () {
        const canvas = document.getElementById("starfield");
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        let stars = [];

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
          generate();
        }

        function generate() {
          const count = Math.min(150, Math.floor((canvas.width * canvas.height) / 10000));
          stars = [];
          for (let i = 0; i < count; i++) {
            stars.push({
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              r: Math.random() * 1.2 + 0.2,
              a: Math.random() * 0.4 + 0.1,
              speed: Math.random() * 0.0003 + 0.0001,
              phase: Math.random() * Math.PI * 2,
            });
          }
          draw();
        }

        function draw(time) {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          for (const s of stars) {
            const twinkle = 0.5 + 0.5 * Math.sin(time * s.speed + s.phase);
            const alpha = s.a * (0.6 + 0.4 * twinkle);
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(232, 228, 240, ${alpha})`;
            ctx.fill();
          }
          requestAnimationFrame(draw);
        }

        window.addEventListener("resize", resize);
        resize();
        requestAnimationFrame(draw);
      })();

      /*-- Nav menu & cursor glow --*/
      const button = document.getElementById("menuToggle");
      const nav = document.getElementById("siteNav");
      const glow = document.getElementById("cursorGlow");
      let frame = 0;

      if (button && nav) {
        button.addEventListener("click", () => {
          const isOpen = nav.dataset.open === "true";
          nav.dataset.open = String(!isOpen);
          button.setAttribute("aria-expanded", String(!isOpen));
        });
      }

      const updateGlow = (x, y) => {
        if (!glow) return;
        glow.style.left = `${x}px`;
        glow.style.top = `${y + 22}px`;
      };

      window.addEventListener("pointermove", (event) => {
        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          updateGlow(event.clientX, event.clientY);
          frame = 0;
        });
      });

      window.addEventListener("mousemove", (event) => {
        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          updateGlow(event.clientX, event.clientY);
          frame = 0;
        });
      });

      window.addEventListener(
        "pointerleave",
        () => {
          updateGlow(window.innerWidth * 0.5, window.innerHeight * 0.22);
        },
        { passive: true },
      );
    </script>
  </body>
</html>
