---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllNotes, formatDate } from '../../lib/content';

const notes = await getAllNotes();
---

<BaseLayout title="BlogX_x | 笔记" description="BlogX_x 的碎片化学习笔记。">
  <section>
    <h1 class="section-title">碎片笔记</h1>
    <p class="meta">短记录，按时间倒序。</p>
  </section>

  <ul class="section stagger" style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.85rem;">
    {notes.map((note) => (
      <li class="card">
        <p style="margin: 0 0 0.35rem;">
          <span style="margin-right: 0.45rem;">{note.data.mood ?? '✍️'}</span>
          <span class="meta">{formatDate(note.data.date)}</span>
        </p>
        <p style="margin: 0;">{note.body}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
