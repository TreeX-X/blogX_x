---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllNotes, formatDate, getEntrySlug } from "../../lib/content";

export async function getStaticPaths() {
  const notes = await getAllNotes();
  return notes.map((note) => ({
    params: { slug: getEntrySlug(note) },
  }));
}

const params = Astro.params;
const notes = await getAllNotes();
const note = notes.find((n) => getEntrySlug(n) === params.slug);
if (!note) throw new Error(`Note not found: ${params.slug}`);
---

<BaseLayout
  title={`${formatDate(note.data.date)} | 笔记 | BlogX_x`}
  description={note.body.slice(0, 80)}
>
  <article class="prose-wrap">
    <header class="post-head">
      <p class="meta">{formatDate(note.data.date)}</p>
      <h1 style="font-size: clamp(1.6rem, 1.45rem + 1.1vw, 2.1rem); margin: 0.2rem 0 1rem;">
        {note.data.mood ?? "✍️"} 笔记
      </h1>
    </header>
    <p style="white-space: pre-wrap;">{note.body}</p>
  </article>
</BaseLayout>
