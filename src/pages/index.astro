---
import BaseLayout from "../layouts/BaseLayout.astro";
import KnowledgeGraph from "../components/KnowledgeGraph";
import {
	getKnowledgeBaseEntries,
	getPublishedPosts,
	getContentDate,
	getContentSummary,
	getContentTitle,
	getEntryPath,
	getEntrySlug,
	formatDate,
} from "../lib/content";

const posts = (await getPublishedPosts()).slice(0, 3);
const knowledgeEntries = (await getKnowledgeBaseEntries()).slice(0, 3);
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
	const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
	const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
	return normalizedPath
		? `${normalizedBase}/${normalizedPath}`
		: `${normalizedBase}/`;
};
---

<BaseLayout
	title="BlogX_x | 首页"
	description="BlogX_x 是一个个人数字花园，沉淀技术文章与本地知识库。"
>
	{/* ===== Hero ===== */}
	<section class="hero">
		<div class="hero-content">
			<div class="hero-badge">PERSONAL DIGITAL GARDEN</div>
			<h1 class="hero-title">
				树码空间
			</h1>
			<div class="hairline"></div>
			<p class="hero-subtitle">
				长篇技术文章与本地知识库，以 AI 驱动搜索与知识图谱。<br />
				没有多余装饰，只有清晰结构与持续迭代。
			</p>

			<div class="hero-search">
				<form
					id="siteSearchForm"
					class="ai-search-form"
					data-api={toBase("api/ai-search")}
					data-base={toBase()}
					data-scope="site"
				>
					<div class="hero-search-container">
						<input
							id="siteSearchInput"
							name="q"
							type="search"
							placeholder="搜索文章、知识库、概念..."
							autocomplete="off"
						/>
						<button type="submit" class="hero-search-btn" id="searchButton">
							搜索
						</button>
					</div>
					<div id="aiTypingIndicator" class="ai-typing-indicator" style="display: none;">
						<span class="typing-dots">
							<span></span>
							<span></span>
							<span></span>
						</span>
						<span class="typing-text">AI 正在思考...</span>
					</div>
				</form>
				<p class="hero-search-hint">支持自然语言提问，AI 自动检索并生成回答</p>
			</div>

			<div id="aiChatContext" class="ai-chat-context" style="display: none; max-width: 520px; margin: 1rem 0 0;">
				<div class="chat-header">
					<h3>AI 对话</h3>
					<button id="clearChat" class="clear-chat-btn">清除对话</button>
				</div>
				<div id="chatMessages" class="chat-messages"></div>
			</div>
			<div id="searchStatus" class="meta" style="margin: 0.5rem 0 0.75rem;"></div>
			<div id="searchResults" class="search-results" style="max-width: 520px;" aria-live="polite"></div>
		</div>

		<div class="hero-panel">
			<div class="hero-graph">
				<KnowledgeGraph
					apiUrl={toBase("api/knowledge-graph")}
					client:media="(min-width: 1025px)"
				/>
			</div>
			<div class="hero-stats">
				<div class="hero-stat">
					<div class="hero-stat-value">{posts.length * 10}+</div>
					<div class="hero-stat-label">articles</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-value">{knowledgeEntries.length * 5}+</div>
					<div class="hero-stat-label">knowledge entries</div>
				</div>
			</div>
		</div>
	</section>

	{/* ===== Features ===== */}
	<div class="features stagger">
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
			</div>
			<h3 class="feature-title">AI 智能搜索</h3>
			<p class="feature-desc">基于向量检索与大语言模型，用自然语言提问即可获得精准回答与相关文章。</p>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
			</div>
			<h3 class="feature-title">知识图谱</h3>
			<p class="feature-desc">基于向量相似度自动构建关系网络，可视化探索知识之间的隐含联系。</p>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 24 24"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
			</div>
			<h3 class="feature-title">数字花园</h3>
			<p class="feature-desc">Obsidian 知识库双向同步，文章与笔记相互链接，持续生长的知识网络。</p>
		</div>
	</div>

	{/* ===== Content Sections ===== */}
	<div class="home-layout section">
		<div class="home-main">
			<section>
				<div class="section-header">
					<h2 class="section-title">最新文章</h2>
					<a class="section-link" href={toBase("posts")}>查看全部 &rarr;</a>
				</div>
				<div class="stagger" style="display: grid; gap: 0.75rem;">
					{
						posts.map((post) => (
							<a class="card" href={toBase(`posts/${getEntrySlug(post)}`)}>
								<h3>{post.data.title}</h3>
								<p class="meta" style="margin: 0 0 0.3rem;">
									{formatDate(post.data.date)}
								</p>
								<p>{post.data.description}</p>
								{post.data.tags?.length ? (
									<div class="tag-list" aria-label="文章标签">
										{post.data.tags.map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								) : null}
							</a>
						))
					}
				</div>
			</section>

			<section class="section">
				<div class="section-header">
					<h2 class="section-title">最近知识库</h2>
					<a class="section-link" href={toBase("knowledge-base")}>查看全部 &rarr;</a>
				</div>
				<div class="stagger" style="display: grid; gap: 0.75rem;">
					{
						knowledgeEntries.map((entry) => (
							<a class="card" href={toBase(`knowledge-base/${getEntryPath(entry)}`)}>
								<p class="meta" style="margin: 0 0 0.25rem;">
									{formatDate(getContentDate(entry))}
								</p>
								<h3>{getContentTitle(entry)}</h3>
								<p>{getContentSummary(entry, 88)}</p>
							</a>
						))
					}
				</div>
			</section>
		</div>

		<aside class="home-sidebar">
			<h2 class="section-title" style="margin-bottom: 0.6rem;">知识图谱</h2>
			<p class="meta" style="margin: 0 0 0.65rem;">
				基于向量相似度自动构建关系网络。
			</p>
			<KnowledgeGraph
				apiUrl={toBase("api/knowledge-graph")}
				client:media="(min-width: 901px)"
			/>
		</aside>
	</div>

	<script is:inline>
		(function() {
			var form = document.getElementById("siteSearchForm");
			var input = document.getElementById("siteSearchInput");
			var status = document.getElementById("searchStatus");
			var results = document.getElementById("searchResults");
			var typingIndicator = document.getElementById("aiTypingIndicator");
			var chatContext = document.getElementById("aiChatContext");
			var chatMessages = document.getElementById("chatMessages");
			var clearChatBtn = document.getElementById("clearChat");
			var chatHistory = [];

			function escapeHtml(value) {
				return value
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;")
					.replace(/"/g, "&quot;")
					.replace(/'/g, "&#039;");
			}

			function toAbsolute(base, url) {
				if (!url) return "#";
				if (url.indexOf("/") !== 0) return url;
				var normalizedBase = base;
				if (base.charAt(base.length - 1) === "/") {
					normalizedBase = base.substring(0, base.length - 1);
				}
				return normalizedBase + url;
			}

			function formatTime(date) {
				var hours = date.getHours();
				var minutes = date.getMinutes();
				return (hours < 10 ? "0" : "") + hours + ":" + (minutes < 10 ? "0" : "") + minutes;
			}

			function addChatMessage(content, isUser) {
				var messageDiv = document.createElement("div");
				messageDiv.className = "chat-message " + (isUser ? "user" : "ai");
				var time = formatTime(new Date());
				messageDiv.innerHTML = '<p class="message-content">' + escapeHtml(content) + '</p><span class="message-time">' + time + '</span>';
				chatMessages.appendChild(messageDiv);
				chatMessages.scrollTop = chatMessages.scrollHeight;
				if (!isUser) {
					chatHistory.push({ content: content, role: "ai", timestamp: time });
				}
			}

			function showResults(items) {
				if (!items || items.length === 0) {
					status.textContent = "没有找到相关内容。";
					return;
				}
				var html = "";
				for (var i = 0; i < items.length; i++) {
					var item = items[i];
					var itemContent = item.content || "";
					var displayContent = itemContent.length > 90 ? itemContent.substring(0, 90) : itemContent;
					html += '<a class="card" href="' + toAbsolute(form.dataset.base, item.url) + '">';
					html += '<h3 style="margin: 0 0 0.25rem;">' + escapeHtml(item.title || "") + '</h3>';
					html += '<p class="meta" style="margin: 0 0 0.3rem;">' + escapeHtml(item.collection || "") + '</p>';
					html += '<p style="margin: 0;">' + escapeHtml(displayContent) + '...</p>';
					html += '</a>';
				}
				results.innerHTML = html;
			}

			if (form && input && status && results && typingIndicator && chatContext && chatMessages) {
				form.addEventListener("submit", function(event) {
					event.preventDefault();
					event.stopPropagation();

					var query = input.value.trim();
					if (!query) {
						status.textContent = "请输入搜索内容。";
						results.innerHTML = "";
						return;
					}

					var api = form.dataset.api;
					var baseVal = form.dataset.base || "/";
					var scope = form.dataset.scope || "site";

					typingIndicator.style.display = "flex";
					chatContext.style.display = "block";
					status.textContent = "正在搜索...";
					results.innerHTML = "";

					chatMessages.innerHTML = "";
					chatHistory = [];

					addChatMessage(query, true);

					fetch(api, {
						method: "POST",
						headers: {
							"Content-Type": "application/json",
						},
							body: JSON.stringify({ q: query, limit: 6, scope: scope }),
					})
					.then(function(response) {
						return response.json();
					})
					.then(function(payload) {
						typingIndicator.style.display = "none";
						status.textContent = "";
						if (payload.aiResponse) {
							addChatMessage(payload.aiResponse);
						}
						if (payload.results) {
							showResults(payload.results);
						}
					})
					.catch(function(error) {
						typingIndicator.style.display = "none";
						status.textContent = "搜索失败：" + error.message;
						results.innerHTML = "";
					});
				});

				if (clearChatBtn) {
					clearChatBtn.addEventListener("click", function() {
						chatMessages.innerHTML = "";
						chatHistory = [];
						chatContext.style.display = "none";
						status.textContent = "";
						results.innerHTML = "";
						input.value = "";
						input.focus();
					});
				}
			}
		})();
	</script>
</BaseLayout>
