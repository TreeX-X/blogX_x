---
import BaseLayout from "../layouts/BaseLayout.astro";
import KnowledgeGraph from "../components/KnowledgeGraph";
import {
	getKnowledgeBaseEntries,
	getPublishedPosts,
	getContentDate,
	getContentSummary,
	getContentTitle,
	getEntryPath,
	getEntrySlug,
	formatDate,
} from "../lib/content";

const posts = (await getPublishedPosts()).slice(0, 3);
const knowledgeEntries = (await getKnowledgeBaseEntries()).slice(0, 3);
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
	const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
	const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
	return normalizedPath
		? `${normalizedBase}/${normalizedPath}`
		: `${normalizedBase}/`;
};
---

<BaseLayout
	title="BlogX_x | 首页"
	description="BlogX_x 是一个极简黑白风格的个人数字花园。"
>
	<section>
		<p class="meta">PERSONAL DIGITAL GARDEN</p>
		<h1
			class="section-title"
			style="font-size: clamp(2rem, 1.6rem + 2vw, 3rem); margin-bottom: 0.5rem;"
		>
			树码空间
		</h1>
		<p class="meta" style="max-width: 58ch;">
			这里沉淀长篇技术文章与 Obsidian 本地知识库。没有多余装饰，只有清晰结构、可靠信息和持续迭代。
		</p>
	</section>

	<div class="home-layout section">
		<div class="home-main">
			<section>
				<h2 class="section-title">AI 搜索</h2>
				<form
					id="siteSearchForm"
					class="ai-search-form"
					data-api={toBase("api/ai-search")}
					data-base={toBase()}
				>
					<div class="ai-search-container">
						<input
							id="siteSearchInput"
							name="q"
							type="search"
							placeholder="输入问题或关键词，例如：如何使用 Astro？"
							autocomplete="off"
						/>
						<button type="submit" id="searchButton">搜索</button>
					</div>
					<div id="aiTypingIndicator" class="ai-typing-indicator" style="display: none;">
						<span class="typing-dots">
							<span></span>
							<span></span>
							<span></span>
						</span>
						<span class="typing-text">AI 正在思考...</span>
					</div>
				</form>
				<div id="aiChatContext" class="ai-chat-context" style="display: none;">
					<div class="chat-header">
						<h3>AI 对话</h3>
						<button id="clearChat" class="clear-chat-btn">清除对话</button>
					</div>
					<div id="chatMessages" class="chat-messages"></div>
				</div>
				<div id="searchStatus" class="meta" style="margin: 0.55rem 0 0.9rem;"></div>
				<div id="searchResults" class="search-results" aria-live="polite"></div>
			</section>

			<section class="section">
				<div
					style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;"
				>
					<h2 class="section-title">最新文章</h2>
					<a class="meta" href={toBase("posts")}>查看全部 →</a>
				</div>
				<div class="stagger" style="display: grid; gap: 0.8rem;">
					{
						posts.map((post) => (
							<a class="card" href={toBase(`posts/${getEntrySlug(post)}`)}>
								<h3 style="margin: 0 0 0.35rem;">{post.data.title}</h3>
								<p class="meta" style="margin: 0 0 0.4rem;">
									{formatDate(post.data.date)}
								</p>
								<p style="margin: 0;">{post.data.description}</p>
								{post.data.tags?.length ? (
									<div class="tag-list" aria-label="文章标签">
										{post.data.tags.map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								) : null}
							</a>
						))
					}
				</div>
			</section>

			<section class="section">
				<div
					style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;"
				>
					<h2 class="section-title">最近知识库</h2>
					<a class="meta" href={toBase("knowledge-base")}>查看全部 →</a>
				</div>
				<div class="stagger" style="display: grid; gap: 0.8rem;">
					{
						knowledgeEntries.map((entry) => (
							<a class="card" href={toBase(`knowledge-base/${getEntryPath(entry)}`)}>
								<p class="meta" style="margin: 0 0 0.35rem;">
									{formatDate(getContentDate(entry))}
								</p>
								<h3 style="margin: 0 0 0.35rem;">{getContentTitle(entry)}</h3>
								<p style="margin: 0;">{getContentSummary(entry, 88)}</p>
							</a>
						))
					}
				</div>
			</section>
		</div>

		<aside class="home-sidebar">
			<h2 class="section-title" style="margin-bottom: 0.7rem;">知识图谱</h2>
			<p class="meta" style="margin: 0 0 0.75rem;">
				基于向量相似度自动构建关系网络。
			</p>
			<KnowledgeGraph
				apiUrl={toBase("api/knowledge-graph")}
				client:media="(min-width: 901px)"
			/>
		</aside>
	</div>
</BaseLayout>

<script is:inline>
	const form = document.getElementById("siteSearchForm");
	const input = document.getElementById("siteSearchInput");
	const status = document.getElementById("searchStatus");
	const results = document.getElementById("searchResults");
	const typingIndicator = document.getElementById("aiTypingIndicator");
	const chatContext = document.getElementById("aiChatContext");
	const chatMessages = document.getElementById("chatMessages");
	const clearChatBtn = document.getElementById("clearChat");
	let chatHistory = [];

	const escapeHtml = (value) =>
		value
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;")
			.replace(/'/g, "&#039;");

	const toAbsolute = (base, url) => {
		if (!url) return "#";
		if (!url.startsWith("/")) return url;
		const normalizedBase = base.endsWith("/") ? base.slice(0, -1);
		return `${normalizedBase}${url}`;
	};

	const formatTime = (date) => {
		return new Intl.DateTimeFormat('zh-CN', {
			hour: '2-digit',
			minute: '2-digit'
		}).format(date);
	};

	const addChatMessage = (content, isUser = false) => {
		const messageDiv = document.createElement('div');
		messageDiv.className = `chat-message ${isUser ? 'user' : 'ai'}`;

		const time = formatTime(new Date());
		messageDiv.innerHTML = `
			<p class="message-content">${content}</p>
			<span class="message-time">${time}</span>
		`;

		chatMessages.appendChild(messageDiv);
		chatMessages.scrollTop = chatMessages.scrollHeight;

		if (!isUser) {
			chatHistory.push({ content, role: 'ai', timestamp: time });
		}
	};

	const showResults = (items) => {
		if (!items.length) {
			status.textContent = "没有找到相关内容。";
			return;
		}

		results.innerHTML = items
			.map(
				(item) => `
					<a class="card" href="${toAbsolute(form.dataset.base, item.url)}">
						<h3 style="margin: 0 0 0.32rem;">${escapeHtml(item.title)}</h3>
						<p class="meta" style="margin: 0 0 0.38rem;">${escapeHtml(item.collection)}</p>
						<p style="margin: 0;">${escapeHtml(item.content).slice(0, 90)}...</p>
					</a>
				`,
			)
			.join("");
	};

	if (form && input && status && results && typingIndicator && chatContext && chatMessages) {
		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			const query = input.value.trim();
			if (!query) {
				status.textContent = "请输入搜索内容。";
				results.innerHTML = "";
				return;
			}

			const api = form.dataset.api;
			const base = form.dataset.base ?? "/";

			// 显示输入指示器和聊天上下文
			typingIndicator.style.display = "flex";
			chatContext.style.display = "block";
			status.textContent = "";
			results.innerHTML = "";

			// 添加用户消息到聊天历史
			chatHistory.push({ content: query, role: 'user', timestamp: formatTime(new Date()) });
			addChatMessage(query, true);

			try {
				const response = await fetch(`${api}`, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ q: query, limit: 6 }),
				});

				const payload = await response.json();
				if (!response.ok) throw new Error(payload?.error ?? "搜索失败");

				typingIndicator.style.display = "none";

				// 显示 AI 回复
				status.textContent = "";
				if (payload.aiResponse) {
					addChatMessage(payload.aiResponse);
				}

				// 显示搜索结果
				if (payload.results) {
					showResults(payload.results);
				}
			} catch (error) {
				typingIndicator.style.display = "none";
				status.textContent = `搜索失败：${error.message}`;
				results.innerHTML = "";
			}
		});

		if (clearChatBtn) {
			clearChatBtn.addEventListener("click", () => {
				chatMessages.innerHTML = "";
				chatHistory = [];
				chatContext.style.display = "none";
				status.textContent = "";
				results.innerHTML = "";
				input.value = "";
				input.focus();
			});
		}
	}
</script>
