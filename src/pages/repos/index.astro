---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRepos } from "../../lib/content";

const repos = await getRepos();

const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};

function formatStars(n?: number) {
  if (!n) return "";
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(/\.0$/, "")}k`;
  return String(n);
}

const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  Python: "#3572A5",
  Shell: "#89e051",
  HTML: "#e34c26",
  JavaScript: "#f1e05a",
  Go: "#00ADD8",
  Rust: "#dea584",
};
---

<BaseLayout title="BlogX_x | 仓库" description="精选开源代码仓库，涵盖 AI Agent、开发者工具等领域。">
  <section>
    <h1 class="section-title">精选仓库</h1>
    <p class="meta">值得关注的开源项目与代码仓库。共 {repos.length} 个。</p>
  </section>

  <section class="section">
    <div class="repos-grid stagger">
      {repos.map((repo) => (
        <a class="repo-card" href={repo.data.repoUrl} target="_blank" rel="noopener noreferrer">
          <div class="repo-card-head">
            <span class="repo-icon">
              <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
                <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8.5ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"/>
              </svg>
            </span>
            <span class="repo-name">{repo.data.title}</span>
            {repo.data.stars ? (
              <span class="repo-stars">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.6;">
                  <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
                </svg>
                {formatStars(repo.data.stars)}
              </span>
            ) : null}
          </div>
          <p class="repo-desc">{repo.data.description}</p>
          <div class="repo-card-foot">
            {repo.data.language ? (
              <span class="repo-lang">
                <span class="repo-lang-dot" style={`background: ${langColors[repo.data.language] || "#999"}`} />
                {repo.data.language}
              </span>
            ) : null}
            {repo.data.tags?.length ? (
              <div class="repo-tags">
                {repo.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            ) : null}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
