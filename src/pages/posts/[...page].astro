---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, formatDate } from '../../lib/content';

export async function getStaticPaths({ paginate }) {
  const posts = await getPublishedPosts();
  return paginate(posts, { pageSize: 5 });
}

const { page } = Astro.props;
---

<BaseLayout title={`BlogX_x | 文章列表 - 第 ${page.currentPage} 页`} description="BlogX_x 的全部技术文章列表。">
  <section>
    <h1 class="section-title">文章</h1>
    <p class="meta">按时间倒序展示，当前第 {page.currentPage} / {page.lastPage} 页。</p>
  </section>

  <section class="section">
    <div class="stagger" style="display: grid; gap: 0.9rem;">
      {page.data.map((post) => (
        <a class="card" href={`/posts/${post.slug ?? post.id}`}>
          <h2 style="margin: 0 0 0.35rem; font-size: 1.2rem;">{post.data.title}</h2>
          <p class="meta" style="margin: 0 0 0.4rem;">{formatDate(post.data.date)}</p>
          <p style="margin: 0;">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <nav class="section" style="display: flex; justify-content: space-between; gap: 1rem;">
    {page.url.prev ? <a class="card" href={page.url.prev}>← 上一页</a> : <span class="meta"> </span>}
    {page.url.next ? <a class="card" href={page.url.next}>下一页 →</a> : <span class="meta"> </span>}
  </nav>
</BaseLayout>
