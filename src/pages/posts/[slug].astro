---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { getPublishedPosts, formatDate } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.slug ?? post.id },
  }));
}

const params = Astro.params;
const posts = await getPublishedPosts();
const post = posts.find((p) => p.slug === params.slug || p.id === params.slug);
if (!post) throw new Error(`Post not found: ${params.slug}`);
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | BlogX_x`}
  description={post.data.description}
>
  <article class="prose-wrap">
    <header class="post-head">
      <p class="meta">{formatDate(post.data.date)}</p>
      <h1
        style="font-size: clamp(1.8rem, 1.55rem + 1.4vw, 2.5rem); margin: 0.2rem 0 1rem;"
      >
        {post.data.title}
      </h1>
      <p class="meta" style="margin-bottom: 0.85rem;">{post.data.description}</p>
      {post.data.tags?.length ? (
        <div class="tag-list" aria-label="文章标签">
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      ) : null}
    </header>
    <Content />
  </article>
</BaseLayout>
