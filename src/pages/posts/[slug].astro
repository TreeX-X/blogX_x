---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, formatDate } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  // 只返回可序列化的 params，避免将包含函数的对象传入 props
  if (posts.length > 0) {
    console.log("=== 正在检查第一篇文章的数据 ===");
    console.log("有没有 slug? :", posts[0].slug);
    console.log("有没有 id? :", posts[0].id);
  }
  return posts.map((post) => ({
    params: { slug: post.slug || post.id },
  }));
}

const params = Astro.params;
const posts = await getPublishedPosts();
const post = posts.find((p) => p.slug === params.slug || p.id === params.slug);
if (!post) throw new Error(`Post not found: ${params.slug}`);
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} | BlogX_x`}
  description={post.data.description}
>
  <article class="prose-wrap">
    <p class="meta">{formatDate(post.data.date)}</p>
    <h1
      style="font-size: clamp(1.8rem, 1.55rem + 1.4vw, 2.5rem); margin: 0.2rem 0 1rem;"
    >
      {post.data.title}
    </h1>
    <p class="meta" style="margin-bottom: 1.4rem;">{post.data.description}</p>
    <Content />
  </article>
</BaseLayout>
