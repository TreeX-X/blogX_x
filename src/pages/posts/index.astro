---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, formatDate, getEntrySlug, getContentTitle, getContentDate } from "../../lib/content";
import { getArticleBySlug, extractDomain } from "../../lib/article-db";

const posts = await getPublishedPosts();
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};

/*-- 预加载文章的 LanceDB 数据（封面图、来源等） --*/
const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const slug = getEntrySlug(post);
    const article = await getArticleBySlug(slug);
    return { post, slug, article };
  })
);
---

<BaseLayout title="BlogX_x | 文章收藏" description="BlogX_x 收藏的优秀技术文章。">
  <section>
    <h1 class="section-title">文章收藏</h1>
    <p class="meta">精选外链好文，构建时自动抓取并翻译。共 {posts.length} 篇。</p>
  </section>

  <section class="section">
    <div class="stagger" style="display: grid; gap: 0.9rem;">
      {postsWithMeta.map(({ post, slug, article }) => (
        <a class="card article-card" href={toBase(`posts/${slug}`)}>
          {article?.coverImage ? (
            <div class="article-card-cover">
              <img src={article.coverImage} alt="" loading="lazy" />
            </div>
          ) : null}
          <div class="article-card-body">
            <h2 style="margin: 0 0 0.35rem; font-size: 1.2rem;">
              {getContentTitle(post)}
            </h2>
            <div class="article-card-meta">
              {article?.author && <span>✍️ {article.author}</span>}
              {post.data.sourceUrl && (
                <span>🌐 {extractDomain(post.data.sourceUrl)}</span>
              )}
              <span class="meta">{formatDate(getContentDate(post))}</span>
            </div>
            {article?.description || post.data.description ? (
              <p style="margin: 0.3rem 0 0;">{article?.description || post.data.description}</p>
            ) : null}
            <div class="article-card-bottom">
              {post.data.tags?.length ? (
                <div class="tag-list" aria-label="文章标签">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              ) : null}
              <div class="article-card-lang">
                {article?.translatedContent ? (
                  /*-- 双语文章：显示合并标识 --*/
                  <span class="lang-badge lang-bilingual">EN/中</span>
                ) : (
                  <Fragment>
                    <span class="lang-badge lang-available">EN</span>
                    <span class="lang-badge lang-unavailable">中</span>
                  </Fragment>
                )}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
