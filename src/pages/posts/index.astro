---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, formatDate, getEntrySlug } from "../../lib/content";

const posts = await getPublishedPosts();
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="BlogX_x | 文章列表" description="BlogX_x 的全部技术文章列表。">
  <section>
    <h1 class="section-title">文章</h1>
    <p class="meta">按时间倒序展示，共 {posts.length} 篇。</p>
  </section>

  <section class="section">
    <div class="stagger" style="display: grid; gap: 0.9rem;">
      {posts.map((post) => (
        <a class="card" href={toBase(`posts/${getEntrySlug(post)}`)}>
          <h2 style="margin: 0 0 0.35rem; font-size: 1.2rem;">{post.data.title}</h2>
          <p class="meta" style="margin: 0 0 0.4rem;">{formatDate(post.data.date)}</p>
          <p style="margin: 0;">{post.data.description}</p>
          {post.data.tags?.length ? (
            <div class="tag-list" aria-label="文章标签">
              {post.data.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          ) : null}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
