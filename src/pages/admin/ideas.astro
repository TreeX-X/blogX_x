---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="意见箱 | Admin" description="管理用户提交的点子">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-brand">BlogX_x</div>
      <p class="admin-sidebar-sub">管理面板</p>
      <nav class="admin-nav">
        <a href={toBase("admin")}>仪表盘</a>
        <a href={toBase("admin/posts")}>文章链接</a>
        <a href={toBase("admin/repos")}>仓库链接</a>
        <a href={toBase("admin/toolbox")}>工具箱</a>
        <a href={toBase("admin/skills")}>Skills</a>
        <a href={toBase("admin/messages")}>留言管理</a>
        <a href={toBase("admin/ideas")} class="active">意见箱</a>
      </nav>
      <div class="admin-sidebar-footer">
        <a href={toBase()}>← 返回首页</a>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-page-head">
        <h1 class="admin-page-title">意见箱</h1>
        <div class="admin-filter-bar">
          <button class="admin-btn admin-btn-sm active" data-filter="all" onclick="setFilter('all')">全部</button>
          <button class="admin-btn admin-btn-sm" data-filter="pending" onclick="setFilter('pending')">待审核</button>
          <button class="admin-btn admin-btn-sm" data-filter="approved" onclick="setFilter('approved')">已通过</button>
          <button class="admin-btn admin-btn-sm" data-filter="rejected" onclick="setFilter('rejected')">已拒绝</button>
        </div>
      </div>

      <div id="ideasList" class="ideas-grid"></div>
      <div id="emptyState" class="admin-empty" style="display:none;">暂无点子</div>

      <!-- Review modal -->
      <div id="reviewModal" class="admin-modal" style="display:none;">
        <div class="admin-modal-content">
          <div class="admin-modal-header">
            <h3 id="modalTitle">审核点子</h3>
            <button class="admin-modal-close" onclick="closeModal()">&times;</button>
          </div>
          <div class="admin-modal-body">
            <div id="modalDetails"></div>
            <div class="admin-form" style="margin-top:1rem;">
              <div class="form-group">
                <label>管理员备注</label>
                <input id="adminNote" placeholder="可选：填写说明" />
              </div>
            </div>
            <div class="admin-modal-actions">
              <button class="admin-btn admin-btn-primary" onclick="review('approve', true)">通过 · 已实现</button>
              <button class="admin-btn admin-btn-warn" onclick="review('approve', false)">通过 · 待实现</button>
              <button class="admin-btn admin-btn-danger" onclick="review('reject')">拒绝</button>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    let ideas = [];
    let filter = "all";
    let currentId = null;

    async function load() {
      const res = await fetch("/api/admin/ideas");
      ideas = await res.json();
      render();
    }

    function setFilter(f) {
      filter = f;
      document.querySelectorAll("[data-filter]").forEach(b => {
        b.classList.toggle("active", b.dataset.filter === f);
      });
      render();
    }

    function render() {
      const container = document.getElementById("ideasList");
      const empty = document.getElementById("emptyState");
      const filtered = filter === "all" ? ideas : ideas.filter(i => i.status === filter);
      if (!filtered.length) { container.innerHTML = ""; empty.style.display = ""; return; }
      empty.style.display = "none";
      container.innerHTML = filtered.map(i => {
        const statusMap = { pending: "待审核", approved: "已通过", rejected: "已拒绝" };
        const badgeClass = { pending: "admin-badge-warn", approved: "admin-badge", rejected: "admin-badge-danger" };
        const time = new Date(i.createdAt).toLocaleString("zh-CN");
        const implLabel = i.status === "approved" ? (i.implemented ? " · 已实现" : " · 待实现") : "";
        return `<div class="idea-card" onclick="openModal('${i.id}')">
          <div class="idea-card-head">
            <span class="idea-card-name">${escapeHtml(i.name)}</span>
            <span class="admin-badge ${badgeClass[i.status] || ''}">${statusMap[i.status] || i.status}${implLabel}</span>
          </div>
          <p class="idea-card-text">${escapeHtml(i.idea)}</p>
          <div class="idea-card-foot">
            <span>${time}</span>
            ${i.adminNote ? `<span class="idea-card-note">备注：${escapeHtml(i.adminNote)}</span>` : ""}
          </div>
        </div>`;
      }).join("");
    }

    function openModal(id) {
      currentId = id;
      const idea = ideas.find(i => i.id === id);
      if (!idea) return;
      document.getElementById("modalTitle").textContent = "审核点子";
      document.getElementById("modalDetails").innerHTML = `
        <p><strong>提交者：</strong>${escapeHtml(idea.name)}</p>
        <p><strong>内容：</strong>${escapeHtml(idea.idea)}</p>
        <p><strong>时间：</strong>${new Date(idea.createdAt).toLocaleString("zh-CN")}</p>
        ${idea.adminNote ? `<p><strong>当前备注：</strong>${escapeHtml(idea.adminNote)}</p>` : ""}
      `;
      document.getElementById("adminNote").value = "";
      document.getElementById("reviewModal").style.display = "flex";
    }

    function closeModal() {
      document.getElementById("reviewModal").style.display = "none";
      currentId = null;
    }

    async function review(action, implemented) {
      if (!currentId) return;
      const adminNote = document.getElementById("adminNote").value.trim();
      await fetch("/api/admin/ideas", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: currentId, action, implemented: !!implemented, adminNote }),
      });
      closeModal();
      load();
    }

    async function deleteIdea(id) {
      if (!confirm("删除这条点子？")) return;
      await fetch("/api/admin/ideas", {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id }),
      });
      load();
    }

    function escapeHtml(t) {
      const d = document.createElement("div");
      d.textContent = t;
      return d.innerHTML;
    }

    // Close modal on backdrop click
    document.getElementById("reviewModal").addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeModal();
    });

    load();
  </script>
</BaseLayout>
