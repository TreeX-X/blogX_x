---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getKnowledgeBaseEntries,
  getContentDate,
  getContentSummary,
  getContentTitle,
  getEntryPath,
  formatDate,
} from "../../lib/content";

const entries = await getKnowledgeBaseEntries();
const groupedEntries = entries.reduce(
  (acc, entry) => {
    const entryPath = getEntryPath(entry);
    const [groupName] = entryPath.split("/");
    const key = groupName || "未分类";
    if (!acc[key]) acc[key] = [];
    acc[key].push(entry);
    return acc;
  },
  {} as Record<string, typeof entries>
);

const groupNames = Object.keys(groupedEntries).sort((a, b) => a.localeCompare(b, "zh-CN"));
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="BlogX_x | 知识库" description="来自 Obsidian 的本地知识库内容。">
  <section>
    <h1 class="section-title">知识库</h1>
    <p class="meta">已同步 {entries.length} 条，按时间倒序展示。</p>
  </section>

  <section class="section">
    <div class="stagger" style="display: grid; gap: 1.2rem;">
      {groupNames.map((groupName) => (
        <section class="kg-group">
          <h2 class="section-title" style="font-size: 1.2rem; margin-bottom: 0.7rem;">{groupName}</h2>
          <div style="display: grid; gap: 0.9rem;">
            {groupedEntries[groupName].map((entry) => (
              <a class="card" href={toBase(`knowledge-base/${getEntryPath(entry)}`)}>
                <p class="meta" style="margin: 0 0 0.35rem;">{formatDate(getContentDate(entry))}</p>
                <h3 style="margin: 0 0 0.4rem; font-size: 1.05rem;">{getContentTitle(entry)}</h3>
                <p style="margin: 0;">{getContentSummary(entry, 120)}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
