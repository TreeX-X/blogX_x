---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getKnowledgeBaseEntries,
  getContentDate,
  getContentSummary,
  getContentTitle,
  getEntryPath,
  formatDate,
} from "../../lib/content";

const entries = await getKnowledgeBaseEntries();
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="BlogX_x | 知识库" description="来自 Obsidian 的本地知识库内容。">
  <section>
    <h1 class="section-title">知识库</h1>
    <p class="meta">已同步 {entries.length} 条，按时间倒序展示。</p>
  </section>

  <section class="section">
    <div class="stagger" style="display: grid; gap: 0.9rem;">
      {entries.map((entry) => (
        <a class="card" href={toBase(`knowledge-base/${getEntryPath(entry)}`)}>
          <p class="meta" style="margin: 0 0 0.35rem;">{formatDate(getContentDate(entry))}</p>
          <h2 style="margin: 0 0 0.4rem; font-size: 1.2rem;">{getContentTitle(entry)}</h2>
          <p style="margin: 0;">{getContentSummary(entry, 120)}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
