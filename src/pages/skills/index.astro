---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSkills } from "../../lib/content";
import { getEntryPath } from "../../lib/content";

const skills = await getSkills();

const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="BlogX_x | Skills" description="精选 Skill 分享——开箱即用的 AI 工作流技能包。">
  <section>
    <h1 class="section-title">Skills</h1>
    <p class="meta">精选 Skill 分享，开箱即用。共 {skills.length} 个。</p>
  </section>

  <section class="section">
    <div class="skills-grid stagger">
      {skills.map((skill) => (
        <a class="skill-card" href={toBase(`skills/${getEntryPath(skill)}`)}>
          <div class="skill-card-head">
            <span class="skill-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </span>
            <span class="skill-name">{skill.data.title}</span>
            {skill.data.version ? (
              <span class="skill-version">v{skill.data.version}</span>
            ) : null}
          </div>
          <p class="skill-desc">{skill.data.description}</p>
          <div class="skill-card-foot">
            {skill.data.author ? (
              <span class="skill-author">{skill.data.author}</span>
            ) : null}
            {skill.data.tags?.length ? (
              <div class="skill-tags">
                {skill.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            ) : null}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
