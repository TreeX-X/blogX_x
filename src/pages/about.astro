---
import BaseLayout from "../layouts/BaseLayout.astro";
import FunMessages from "../components/FunMessages";
import IdeaBox from "../components/IdeaBox";

const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};

const funMessagesApi = toBase("api/fun-messages");
const ideasApi = toBase("api/ideas");
---

<BaseLayout title="BlogX_x | 关于" description="关于 BlogX_x 和作者。">
  <section>
    <h1 class="section-title">关于我</h1>
    <div class="card" style="display: grid; gap: 1rem;">
      <div
        style="width: 72px; height: 72px; border-radius: 999px; border: 2px solid var(--line); overflow: hidden; flex-shrink: 0;"
      >
        <img
          src={toBase("about/me.png")}
          alt="avatar"
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
        />
      </div>
      <p style="margin: 0;">
        我在这里记录技术实践、设计思考和知识库沉淀。BlogX_x
        的目标是保持克制表达，长期更新。
      </p>

      <div class="about-social-wrap">
        <a
          class="github-entry"
          href="https://github.com/TreeX-X"
          target="_blank"
          rel="noreferrer"
          aria-label="访问 TreeX-X 的 GitHub 主页"
        >
          <span class="github-entry-ring" aria-hidden="true"></span>
          <span class="github-entry-icon-shell" aria-hidden="true">
            <img
              class="github-entry-icon"
              src={toBase("logo/githubLogo.svg")}
              alt=""
            />
          </span>
          <span class="github-entry-text">@TreeX-X on GitHub</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Fun Messages Section -->
  <section class="section">
    <FunMessages apiUrl={funMessagesApi} client:load />
  </section>

  <!-- Idea Collection Box Section -->
  <section class="section">
    <IdeaBox apiUrl={ideasApi} client:load />
  </section>
</BaseLayout>