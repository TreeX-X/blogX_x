---
import BaseLayout from "../layouts/BaseLayout.astro";
import FunMessages from "../components/FunMessages";
import IdeaBox from "../components/IdeaBox";
import { getProjects } from "../lib/content";

const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};

const funMessagesApi = toBase("api/fun-messages");
const ideasApi = toBase("api/ideas");
const projects = await getProjects();
---

<BaseLayout title="BlogX_x | 关于" description="关于 BlogX_x 和作者。">
  <!-- About Me -->
  <section>
    <h1 class="section-title">关于我</h1>
    <div class="card" style="display: grid; gap: 1rem;">
      <div
        style="width: 72px; height: 72px; border-radius: 999px; border: 2px solid var(--line); overflow: hidden; flex-shrink: 0;"
      >
        <img
          src={toBase("about/me.png")}
          alt="avatar"
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
        />
      </div>
      <p style="margin: 0;">
        我在这里记录技术实践、设计思考和知识库沉淀。BlogX_x
        的目标是保持克制表达，长期更新。
      </p>

      <div class="about-social-wrap">
        <a
          class="github-entry"
          href="https://github.com/TreeX-X"
          target="_blank"
          rel="noreferrer"
          aria-label="访问 TreeX-X 的 GitHub 主页"
        >
          <span class="github-entry-ring" aria-hidden="true"></span>
          <span class="github-entry-icon-shell" aria-hidden="true">
            <img
              class="github-entry-icon"
              src={toBase("logo/githubLogo.svg")}
              alt=""
            />
          </span>
          <span class="github-entry-text">@TreeX-X on GitHub</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Projects Showcase -->
  {projects.length > 0 && (
    <section class="section">
      <h2 class="section-title">我的项目</h2>
      <div class="repos-grid stagger">
        {projects.map((p) => (
          <a class="repo-card" href={p.data.repoUrl} target="_blank" rel="noreferrer">
            <div class="repo-card-head">
              <svg class="repo-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
              <span class="repo-name">{p.data.title}</span>
            </div>
            <p class="repo-desc">{p.data.description}</p>
            {p.data.tags?.length ? (
              <div class="repo-card-foot">
                <div class="repo-tags">
                  {p.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </div>
            ) : null}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Fun Messages Section -->
  <section class="section">
    <FunMessages apiUrl={funMessagesApi} client:load />
  </section>

  <!-- Idea Collection Box Section -->
  <section class="section">
    <IdeaBox apiUrl={ideasApi} client:load />
  </section>
</BaseLayout>
