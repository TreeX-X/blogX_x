---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
const toBase = (path = "") => {
  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
  return normalizedPath ? `${normalizedBase}/${normalizedPath}` : `${normalizedBase}/`;
};
---

<BaseLayout title="BlogX_x | 关于" description="关于 BlogX_x 和作者。">
  <section>
    <h1 class="section-title">关于我</h1>
    <div class="card" style="display: grid; gap: 1rem;">
      <div
        style="width: 72px; height: 72px; border-radius: 999px; border: 2px solid var(--line); overflow: hidden; flex-shrink: 0;"
      >
        <img
          src={toBase("about/me.png")}
          alt="avatar"
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
        />
      </div>
      <p style="margin: 0;">
        我在这里记录技术实践、设计思考和日常学习笔记。BlogX_x
        的目标是保持克制表达，长期更新。
      </p>
    </div>
  </section>
</BaseLayout>
