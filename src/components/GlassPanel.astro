---
interface Props {
  class?: string;
  variant?: "default" | "elevated" | "subtle";
  glow?: boolean;
}

const { class: className = "", variant = "default", glow = false } = Astro.props;
---

<div
  class:list={["glass-panel", `glass-panel--${variant}`, { "glass-panel--glow": glow }, className]}
>
  <slot />
</div>

<style>
  .glass-panel {
    position: relative;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    background: var(--glass-bg);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    overflow: hidden;
  }

  .glass-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      rgba(167, 139, 250, 0.04) 0%,
      transparent 50%,
      rgba(96, 165, 250, 0.02) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .glass-panel--elevated {
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(167, 139, 250, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .glass-panel--subtle {
    background: rgba(12, 9, 20, 0.35);
    backdrop-filter: blur(8px);
    border-color: rgba(167, 139, 250, 0.06);
  }

  .glass-panel--glow::after {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(167, 139, 250, 0.4),
      rgba(96, 165, 250, 0.3),
      transparent
    );
    pointer-events: none;
  }
</style>
